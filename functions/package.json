{
  "name": "edunova-functions",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "powershell -NoProfile -Command \"if (Test-Path lib) { Remove-Item lib -Recurse -Force }\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "npm run build && firebase emulators:start --config ..\\firebase.json --only auth,firestore,functions,storage --project edunova-aabd1",
    "pregenerate": "tsx scripts/pregenerate.ts"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "dotenv": "^17.4.1",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
